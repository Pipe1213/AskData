      "link": null,
      "locked": false,
      "text": "Deterministic Query Pipeline\n\n1. retrieve schema context\n2. generate SQL\n3. validate SQL\n4. execute read-only query\n5. repair once if needed\n6. summarize + chart hint\n7. return structured JSON",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
